[Unit]
# critical6-lock: kernel-level protection against accidental restart.
# RefuseManualStop=yes blocks both 'systemctl stop' AND 'systemctl restart'
# (restart = stop + start; stop refusal prevents both).
# systemd-internal Restart=on-failure is unaffected (process-level, not unit operation).
# Override procedure: see /opt/gcg/shared/CRITICAL6.md
# To permanently remove: rm /etc/systemd/system/openclaw-<agent>.service.d/critical6-lock.conf && systemctl daemon-reload
RefuseManualStop=yes
RefuseManualStart=no
