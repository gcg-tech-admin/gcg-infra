[Unit]
Description=GCG Borg baseline tag — post-incident known-good 2026-05-18
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
ExecStart=/opt/gcg/shared/bin/gcg-borg-baseline.sh
LoadCredentialEncrypted=borg-passphrase:/etc/credstore.encrypted/borg-passphrase
LoadCredentialEncrypted=borg-key:/etc/credstore.encrypted/borg-key
Nice=10
IOSchedulingClass=idle
TimeoutStartSec=2h
