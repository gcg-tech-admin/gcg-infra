[Unit]
Description=OpenClaw Agent - Kira (GCG - Slavyana Rousseau, Account Manager)
After=network.target docker.service
StartLimitBurst=5
StartLimitIntervalSec=300

[Service]
EnvironmentFile=-/opt/gcg/shared/.env-db-secrets
EnvironmentFile=-/opt/gcg/shared/.env.global
Environment=FLEET_AGENT_NAME=kira
Environment=HOOK_AGENT_ID=kira
Type=simple
User=root
WorkingDirectory=/opt/gcg/openclaw-kira
EnvironmentFile=/opt/gcg/openclaw-kira/.env
Environment=OPENCLAW_CONFIG_PATH=/opt/gcg/openclaw-kira/openclaw.json
Environment=OPENCLAW_STATE_DIR=/opt/gcg/openclaw-kira/state
Environment=NODE_OPTIONS=--max-old-space-size=2048
ExecStartPre=/usr/bin/python3 /opt/gcg/shared/scripts/validate-agent-config.py /opt/gcg/openclaw-kira/openclaw.json
ExecStart=/usr/bin/openclaw gateway
ExecStopPost=/opt/gcg/shared/scripts/session-pre-stop-flush.sh
MemoryMax=3G
MemoryHigh=2G
Restart=always
RestartSec=10
StandardOutput=append:/opt/gcg/openclaw-kira/logs/gateway.log
StandardError=append:/opt/gcg/openclaw-kira/logs/gateway.log

[Install]
WantedBy=multi-user.target
