[Unit]
Description=GCG inbox poller for agent %i
After=network-online.target openclaw-%i.service
Wants=network-online.target
# Stop together with the agent; restart when agent restarts
PartOf=openclaw-%i.service

[Service]
Type=simple
# Tight bash loop: poll, sleep, repeat. Keeps memory and complexity near zero.
ExecStart=/bin/bash -c 'while true; do /opt/gcg/shared/bin/gcg-inbox-poll %i || true; sleep 5; done'
Restart=always
RestartSec=3
Nice=10
# Resource caps — poller should never compete with the agent runtime
MemoryMax=64M
CPUQuota=10%
# Hardening
NoNewPrivileges=true
ProtectSystem=strict
ReadWritePaths=/opt/gcg/openclaw-%i/workspace
ProtectHome=true
PrivateTmp=true
ProtectKernelTunables=true
ProtectControlGroups=true
RestrictSUIDSGID=true
LockPersonality=true

[Install]
WantedBy=multi-user.target openclaw-%i.service
