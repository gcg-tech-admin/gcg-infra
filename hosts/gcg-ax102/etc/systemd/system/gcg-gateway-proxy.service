[Unit]
Description=GCG vSwitch Gateway Proxy — forwards 10.0.0.1:18950 → 127.0.0.1:18950
After=network.target
Before=openclaw-talos.service

[Service]
Type=simple
User=root
ExecStart=/usr/bin/socat TCP-LISTEN:18950,bind=10.0.0.1,fork,reuseaddr TCP:127.0.0.1:18950
Restart=always
RestartSec=5
StandardOutput=append:/var/log/gcg-gateway-proxy.log
StandardError=append:/var/log/gcg-gateway-proxy.log

[Install]
WantedBy=multi-user.target
