#!/bin/bash
# gcg-secret-bootstrap.sh — systemd ExecStartPre
# Fetches DeepSeek/Moonshot/Gemini/Anthropic from 1Password,
# writes runtime env to /run/openclaw-${AGENT}/env (tmpfs, 0600).
# Opt-in agents also get Google Workspace SA JSON (DWD) at /run/openclaw-${AGENT}/google-sa.json (tmpfs, 0400).
# Anthropic available for one-off tasks — NOT for recurring processes.
# Plaintext NEVER on persistent disk.
set -e

AGENT="${1:?agent name required}"
RUNTIME_DIR="/run/openclaw-${AGENT}"
mkdir -p "$RUNTIME_DIR"; chmod 700 "$RUNTIME_DIR"

[ -z "$CREDENTIALS_DIRECTORY" ] && { echo "ERROR: no \$CREDENTIALS_DIRECTORY" >&2; exit 2; }

DB_ENV=""
[ -r "$CREDENTIALS_DIRECTORY/db-env" ] && DB_ENV=$(cat "$CREDENTIALS_DIRECTORY/db-env")

PER_AGENT_PWD="/opt/gcg/shared/credentials/db/gcg_${AGENT}.pwd"
if [ -r "$PER_AGENT_PWD" ]; then
  AGENT_DB_PASSWORD=$(tr -d '\n' < "$PER_AGENT_PWD")
  DB_ENV=$(echo "$DB_ENV" | sed "s/^GCG_DB_USER=.*/GCG_DB_USER=gcg_${AGENT}/" | sed "s/^GCG_DB_PASSWORD=.*/GCG_DB_PASSWORD=${AGENT_DB_PASSWORD}/" | sed "s/^PGPASSWORD=.*/PGPASSWORD=${AGENT_DB_PASSWORD}/")
fi

GW_LINE=""
TG_LINE=""
if [ -r "$CREDENTIALS_DIRECTORY/gateway-env" ]; then
  AU=$(echo "$AGENT" | tr "[:lower:]" "[:upper:]")
  GW_LINE=$(grep "^GATEWAY_TOKEN_${AU}=" "$CREDENTIALS_DIRECTORY/gateway-env" || true)
  TG_TOKEN=$(grep "^TELEGRAM_BOT_TOKEN_${AU}=" "$CREDENTIALS_DIRECTORY/gateway-env" | cut -d= -f2- || true)
  [ -n "$TG_TOKEN" ] && TG_LINE="TELEGRAM_BOT_TOKEN=${TG_TOKEN}"
fi

[ -r "$CREDENTIALS_DIRECTORY/op-sa-token" ] || { echo "ERROR: no op-sa-token cred" >&2; exit 3; }
export OP_SERVICE_ACCOUNT_TOKEN=$(cat "$CREDENTIALS_DIRECTORY/op-sa-token")

# Shared keys — single Anthropic key for fleet, available but NOT for recurring/heartbeat use
# UUID-based path: item title "Anthropic / Claude API key" contains literal "/" which collides with op:// separator.
ANTHROPIC_KEY=$(op read "op://GCG Agent Fleet/7jmhrwkjtm62mfx3bnpebf72ki/password" 2>/dev/null || true)
DEEPSEEK_KEY=$(op read "op://GCG Agent Fleet/Deepseek API/password" 2>/dev/null || true)
MOONSHOT_KEY=$(op read "op://GCG Agent Fleet/Moonshot Kimi/credential" 2>/dev/null || true)
GEMINI_KEY=$(op read   "op://GCG Agent Fleet/Gemini Api Key/password" 2>/dev/null || true)
OPENAI_OAUTH=$(op read "op://GCG Agent Fleet/OpenAI OAuth/credential" 2>/dev/null || true)

{
  [ -n "$DB_ENV" ]         && echo "$DB_ENV"
  [ -n "$GW_LINE" ]        && echo "$GW_LINE"
  [ -n "$TG_LINE" ]        && echo "$TG_LINE"
  [ -n "$ANTHROPIC_KEY" ]  && echo "ANTHROPIC_API_KEY=$ANTHROPIC_KEY"
  [ -n "$DEEPSEEK_KEY" ]   && echo "DEEPSEEK_API_KEY=$DEEPSEEK_KEY"
  if [ -n "$MOONSHOT_KEY" ]; then
    echo "MOONSHOT_API_KEY=$MOONSHOT_KEY"
    echo "KIMI_API_KEY=$MOONSHOT_KEY"
  fi
  if [ -n "$GEMINI_KEY" ]; then
    echo "GEMINI_API_KEY=$GEMINI_KEY"
    echo "GOOGLE_API_KEY=$GEMINI_KEY"
  fi
  [ -n "$OPENAI_OAUTH" ]   && echo "OPENAI_OAUTH_TOKEN=$OPENAI_OAUTH"
} > "$RUNTIME_DIR/env"
chmod 600 "$RUNTIME_DIR/env"

# Google Workspace SA (DWD) — opt-in per agent.
# Single shared SA; DWD impersonation target chosen at API call time.
# Rotation: replace the file attachment on the 1Password item, keep the filename stable.
GOOGLE_SA_OP_REF="op://GCG Agent Fleet/sth5aujsjwj54yu2uvnr6klexa/gcg-agents-19e05d85a38d.json"
case "$AGENT" in
  alex|alexa|algaib|angela|anna|argus|bob|daen|goku|hector|kenji|kira|leon|malik|marcus|max|niccolo|nik|phil|talos|tom|varys|vera|viktor|vulcan|yuri)
    GOOGLE_SA_PATH="$RUNTIME_DIR/google-sa.json"
    if op read "$GOOGLE_SA_OP_REF" > "$GOOGLE_SA_PATH" 2>/dev/null && [ -s "$GOOGLE_SA_PATH" ]; then
      chmod 400 "$GOOGLE_SA_PATH"
      echo "GOOGLE_APPLICATION_CREDENTIALS=$GOOGLE_SA_PATH" >> "$RUNTIME_DIR/env"
      echo "gcg-secret-bootstrap: $AGENT google-sa fetched"
    else
      rm -f "$GOOGLE_SA_PATH"
      echo "gcg-secret-bootstrap: WARN $AGENT google-sa fetch failed" >&2
    fi
    ;;
esac


# Anthropic auth-profile (api_key) into openclaw auth-profiles.json — tmpfs+symlink for zero-plaintext compliance.
# Bootstrap is single source of 1Password truth; openclaw reads merged profile at process start.
if [ -n "$ANTHROPIC_KEY" ]; then
  for SUBAGENT in main search; do
    AGENT_DIR="/opt/gcg/openclaw-${AGENT}/state/.openclaw/agents/${SUBAGENT}/agent"
    [ -d "$AGENT_DIR" ] || continue
    TARGET="$AGENT_DIR/auth-profiles.json"
    TEMPLATE="$AGENT_DIR/auth-profiles.template.json"
    TMPFS_AUTH="$RUNTIME_DIR/auth-profiles-${SUBAGENT}.json"
    # First-boot migration: snapshot static profiles (OAuth etc) to template
    if [ ! -f "$TEMPLATE" ] && [ -f "$TARGET" ] && [ ! -L "$TARGET" ]; then
      python3 - "$TARGET" "$TEMPLATE" <<'PYTEMPL'
import json, sys
src_path, tpl_path = sys.argv[1:]
d = json.load(open(src_path))
# Strip api_key entries from template (those are runtime-injected)
d['profiles'] = {k:v for k,v in d.get('profiles',{}).items() if v.get('type') != 'api_key'}
open(tpl_path,'w').write(json.dumps(d, indent=2))
PYTEMPL
    fi
    # Build runtime auth-profiles from template + anthropic api_key
    python3 - "$TEMPLATE" "$TMPFS_AUTH" "$ANTHROPIC_KEY" "$DEEPSEEK_KEY" "$MOONSHOT_KEY" "$GEMINI_KEY" <<'PYBUILD'
import json, os, sys
tpl, tmpfs, anth, deep, moon, gem = sys.argv[1:]
d = json.load(open(tpl)) if os.path.exists(tpl) else {'version':1,'profiles':{}}
profs = d.setdefault('profiles',{})
for prov_id, prov_name, key in [
    ('anthropic:default',  'anthropic', anth),
    ('deepseek:default',   'deepseek',  deep),
    ('moonshot:default',   'moonshot',  moon),
    ('google:default',     'google',    gem),
]:
    if key:
        profs[prov_id] = {'type': 'api_key', 'provider': prov_name, 'apiKey': key}
open(tmpfs,'w').write(json.dumps(d, indent=2))
os.chmod(tmpfs, 0o600)
PYBUILD
    # Replace target with symlink to tmpfs
    if [ -L "$TARGET" ]; then
      ln -sfn "$TMPFS_AUTH" "$TARGET"
    else
      [ -f "$TARGET" ] && cp "$TARGET" "${TARGET}.pre-tmpfs-$(date +%s)" 2>/dev/null
      rm -f "$TARGET"
      ln -s "$TMPFS_AUTH" "$TARGET"
    fi
  done
  echo "gcg-secret-bootstrap: $AGENT anthropic profile injected (tmpfs)"
fi

echo "gcg-secret-bootstrap: $AGENT env written ($(wc -l < "$RUNTIME_DIR/env") lines)"

# manifest.json — self-introspection for the agent (best-effort, never fails bootstrap)
/opt/gcg/shared/bin/gcg-manifest-emit "$AGENT" || true
