#!/usr/bin/env python3
"""
provision-integrations.py — Tier 5/9/10/11 wiring for OpenClaw fleet agents.

Usage:
  provision-integrations.py <name> [--capabilities <yaml|json|@path>] [--dry-run] [--force]

Tiers covered:
  5  — fleet inbox: /fleet hook mapping in hooks.mappings +
         inbox-auto-inject in hooks.internal.entries +
         gcg-inbox-poller@<name>.service enablement
  9  — FLEET.yaml agents.<name> block + AGENTS.md canonical inject
  10 — Asana vault placeholder entry (if api_scopes includes "asana") +
         DWD impersonation allowlist upsert
  11 — Capability validation (skills, DWD/Gmail, MCP servers, API scopes)

Does NOT touch: model routing, memory hooks, systemd unit/service, tokens
(all owned by provision-base or provision-memory).
"""
from __future__ import annotations

import argparse
import copy
import datetime
import hashlib
import json
import os
import subprocess
import sys
import time
from pathlib import Path
from typing import Any

# ─── constants ────────────────────────────────────────────────────────────────

FLEET_YAML         = "/opt/gcg/shared/FLEET.yaml"
SHARED_BIN         = "/opt/gcg/shared/bin"
SHARED_SKILLS      = "/opt/gcg/shared/skills"
ASANA_VAULT        = "/opt/gcg/shared/secrets/asana.enc"
ASANA_VAULT_KEY    = "/opt/gcg/shared/secrets/.vault_key"
AUDIT_LOG          = "/var/log/gcg-provision/integrations.log"
AGENT_DIR_TMPL     = "/opt/gcg/openclaw-{name}"
OPENCLAW_JSON_TMPL = "/opt/gcg/openclaw-{name}/openclaw.json"
INBOX_POLLER_TMPL  = "gcg-inbox-poller@{name}.service"

# Key written by this script into FLEET.yaml agent block
LAST_PROVISIONED_KEY = "last_provisioned_integrations"

CRITICAL_6 = {"daen", "talos", "marcus", "mnemosyne", "vulcan", "nik"}

# Peter's Telegram ID (from canonical marcus config)
PETER_TELEGRAM_ID = "418059105"

# Known fleet skills
KNOWN_SKILLS = {
    "gcg-rotate-pat", "gcg-sales-engine", "cowork-plugin-management",
    "pdf", "docx", "xlsx", "pptx", "canvas-design",
    "google-sheets", "setup-cowork", "consolidate-memory",
}

# Known API scopes → credential reference
KNOWN_API_SCOPES: dict[str, str] = {
    "asana":      "op://GCG Agent Fleet/asana-gcg-shared/credential",
    "slack":      "env:SLACK_BOT_TOKEN",
    "telegram":   "env:TELEGRAM_BOT_TOKEN",
    "heyreach":   "op://GCG Agent Fleet/heyreach-api-key/credential",
    "ghl":        "op://GCG Agent Fleet/ghl-oauth/credential",
    "cloudflare": "op://GCG Agent Fleet/cloudflared-personal-token/credential",
    "hetzner":    "op://GCG Agent Fleet/hetzner-robot/credential",
    "sentry":     "op://GCG Agent Fleet/sentry-dsn/credential",
    "stripe":     "op://GCG Agent Fleet/gcg-stripe-prod/credential",
    "resend":     "op://GCG Agent Fleet/gcg-resend-prod/credential",
    "xero":       "op://GCG Agent Fleet/gcg-xero-prod/credential",
    "twilio":     "op://GCG Agent Fleet/gcg-twilio-prod/credential",
    "whatsapp":   "op://GCG Agent Fleet/whatsapp-business/credential",
    "fathom":     "op://GCG Agent Fleet/fathom-api/credential",
