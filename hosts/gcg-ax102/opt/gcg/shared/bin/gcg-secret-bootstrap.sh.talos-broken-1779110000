#!/bin/bash
if [ -f "/etc/credstore.encrypted/op-sa-token" ]; then
    export OP_SERVICE_ACCOUNT_TOKEN=$(systemd-creds decrypt /etc/credstore.encrypted/op-sa-token -)
fi

if [ -z "${OP_SERVICE_ACCOUNT_TOKEN:-}" ]; then
    return 0 2>/dev/null || exit 0
fi

AGENT_NAME=$(basename "$PWD" | sed 's/^openclaw-//')
AGENT_TITLE="$(tr '[:lower:]' '[:upper:]' <<< ${AGENT_NAME:0:1})${AGENT_NAME:1}"

TG=$(op read "op://GCG Agent Fleet/Telegram ${AGENT_TITLE}/credential" 2>/dev/null || true)
if [ -n "$TG" ]; then export TELEGRAM_BOT_TOKEN="$TG"; fi

# Slack Workspaces
SA_STRUCTURING=$(op read "op://GCG Agent Fleet/Slack gcg-structuring/${AGENT_TITLE} appToken" 2>/dev/null || true)
SB_STRUCTURING=$(op read "op://GCG Agent Fleet/Slack gcg-structuring/${AGENT_TITLE} botToken" 2>/dev/null || true)
if [ -n "$SA_STRUCTURING" ]; then 
    export SLACK_APP_TOKEN_GCG_STRUCTURING="$SA_STRUCTURING"
    export SLACK_APP_TOKEN="$SA_STRUCTURING"
fi
if [ -n "$SB_STRUCTURING" ]; then 
    export SLACK_BOT_TOKEN_GCG_STRUCTURING="$SB_STRUCTURING"
    export SLACK_BOT_TOKEN="$SB_STRUCTURING"
fi

SA_MEDIA=$(op read "op://GCG Agent Fleet/Slack gcg-media/${AGENT_TITLE} appToken" 2>/dev/null || true)
SB_MEDIA=$(op read "op://GCG Agent Fleet/Slack gcg-media/${AGENT_TITLE} botToken" 2>/dev/null || true)
if [ -n "$SA_MEDIA" ]; then export SLACK_APP_TOKEN_GCG_MEDIA="$SA_MEDIA"; fi
if [ -n "$SB_MEDIA" ]; then export SLACK_BOT_TOKEN_GCG_MEDIA="$SB_MEDIA"; fi
