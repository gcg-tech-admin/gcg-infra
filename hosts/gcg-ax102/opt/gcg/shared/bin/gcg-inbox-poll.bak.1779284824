#!/bin/bash
# gcg-inbox-poll — one-shot inbox drain for a single agent.
# Reads pending agent_messages rows for the given recipient, writes one
# JSON file per message into /opt/gcg/openclaw-<agent>/workspace/inbox/,
# marks each delivered row status=acked.
#
# Usage: gcg-inbox-poll <agent>
#
# Designed to run inside a systemd loop (see gcg-inbox-poller@.service).
# Safe to invoke ad-hoc.

set -euo pipefail

AGENT="${1:?usage: gcg-inbox-poll <agent>}"
WS="/opt/gcg/openclaw-${AGENT}/workspace"
INBOX_DIR="${WS}/inbox"
PWD_FILE="/opt/gcg/shared/credentials/db/gcg_fleet.pwd"

[ ! -d "$WS" ] && { echo "gcg-inbox-poll: no workspace for $AGENT" >&2; exit 1; }
[ ! -r "$PWD_FILE" ] && { echo "gcg-inbox-poll: cannot read $PWD_FILE" >&2; exit 1; }

mkdir -p "$INBOX_DIR"
chmod 0750 "$INBOX_DIR" 2>/dev/null || true

PGPW=$(tr -d '\r\n' < "$PWD_FILE")
export PGPASSWORD="$PGPW"

# Atomically claim pending messages: SELECT FOR UPDATE SKIP LOCKED + update to acked.
# Postgres emits one fully-formed JSON envelope per row — no bash parsing.
# Output lines: <id>\t<json_envelope>
ROWS=$(psql "host=95.217.114.49 port=5432 user=gcg_fleet dbname=gcg_intelligence sslmode=require" \
  -v ON_ERROR_STOP=1 -tA -F $'\t' -v agent="$AGENT" <<'SQL'
WITH claimed AS (
  SELECT id
    FROM agent_messages
   WHERE recipient = :'agent' AND status = 'pending'
   ORDER BY priority ASC, issued_at ASC
   FOR UPDATE SKIP LOCKED
   LIMIT 50
),
upd AS (
  UPDATE agent_messages m
     SET status='acked', acked_at=NOW()
    FROM claimed
   WHERE m.id = claimed.id
  RETURNING m.*
)
SELECT
  id,
  jsonb_build_object(
    'id',             id,
    'sender',         sender,
    'recipient',      recipient,
    'correlation_id', correlation_id,
    'parent_id',      parent_id,
    'task_type',      task_type,
    'priority',       priority,
    'issued_at',      to_char(issued_at AT TIME ZONE 'UTC', 'YYYY-MM-DD"T"HH24:MI:SS"Z"'),
    'nonce',          nonce,
    'payload',        payload
  )::text AS envelope
FROM upd
ORDER BY id;
SQL
)

[ -z "$ROWS" ] && exit 0

COUNT=0
while IFS=$'\t' read -r ID ENVELOPE; do
  [ -z "$ID" ] && continue
  TMP="${INBOX_DIR}/.${ID}.json.tmp"
  FINAL="${INBOX_DIR}/${ID}.json"
  printf '%s\n' "$ENVELOPE" > "$TMP"
  chmod 0640 "$TMP"
  mv -f "$TMP" "$FINAL"
  COUNT=$((COUNT+1))
done <<< "$ROWS"

echo "$(date -u +%FT%TZ) gcg-inbox-poll[$AGENT] delivered=$COUNT" >&2
