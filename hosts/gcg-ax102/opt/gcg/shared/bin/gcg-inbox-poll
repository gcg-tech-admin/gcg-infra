#!/bin/bash
# gcg-inbox-poll — one-shot inbox drain for a single agent.
# Reads pending agent_messages rows for the given recipient, writes one
# JSON file per message into /opt/gcg/openclaw-<agent>/workspace/inbox/,
# marks each delivered row status=acked.
#
# Usage: gcg-inbox-poll <agent>
#
# Designed to run inside a systemd loop (see gcg-inbox-poller@.service).
# Safe to invoke ad-hoc.

set -euo pipefail

# ── Error handler ──────────────────────────────────────────────────
# On any unhandled error (via ERR trap or explicit call), log full
# traceback to stderr and notify Peter via /opt/gcg/shared/bin/fleet send.
_fatal() {
  local rc=$?
  local line=$1
  echo "gcg-inbox-poll: FATAL at line ${line} (exit ${rc})" >&2
  # Print bash stack trace
  local frame=0
  while caller $frame >/dev/null 2>&1; do
    caller $frame >&2
    frame=$((frame + 1))
  done
  # Notify Peter: /opt/gcg/shared/bin/fleet send to daen (daen routes to Peter)
  /opt/gcg/shared/bin/fleet send daen "gcg-inbox-poll FAILED for ${AGENT:-?}: error at line ${line}, exit ${rc}" 2>/dev/null || true
  exit ${rc}
}
trap '_fatal ${LINENO}' ERR

AGENT="${1:?usage: gcg-inbox-poll <agent>}"
WS="/opt/gcg/openclaw-${AGENT}/workspace"
INBOX_DIR="${WS}/inbox"
PWD_FILE="/opt/gcg/shared/credentials/db/gcg_fleet.pwd"

[ ! -d "$WS" ] && { echo "gcg-inbox-poll: no workspace for $AGENT" >&2; _fatal 1; }
[ ! -r "$PWD_FILE" ] && { echo "gcg-inbox-poll: cannot read $PWD_FILE" >&2; _fatal 1; }

mkdir -p "$INBOX_DIR"
chmod 0750 "$INBOX_DIR" 2>/dev/null || true

PGPW=$(tr -d '\r\n' < "$PWD_FILE")
export PGPASSWORD="$PGPW"

# Atomically claim pending messages: SELECT FOR UPDATE SKIP LOCKED + update to acked.
# Postgres emits one fully-formed JSON envelope per row — no bash parsing.
# Output lines: <id>\t<json_envelope>
ROWS=$(psql "host=10.0.0.2 port=5432 user=gcg_fleet dbname=gcg_intelligence sslmode=disable" \
  -v ON_ERROR_STOP=1 -tA -F $'\t' -v agent="$AGENT" <<'SQL'
WITH claimed AS (
  SELECT id
    FROM agent_messages
   WHERE recipient = :'agent' AND status = 'pending'
   ORDER BY priority ASC, issued_at ASC
   FOR UPDATE SKIP LOCKED
   LIMIT 50
),
upd AS (
  UPDATE agent_messages m
     SET status='acked', acked_at=NOW()
    FROM claimed
   WHERE m.id = claimed.id
  RETURNING m.*
)
SELECT
  id,
  jsonb_build_object(
    'id',             id,
    'sender',         sender,
    'recipient',      recipient,
    'correlation_id', correlation_id,
    'parent_id',      parent_id,
    'task_type',      task_type,
    'priority',       priority,
    'issued_at',      to_char(issued_at AT TIME ZONE 'UTC', 'YYYY-MM-DD"T"HH24:MI:SS"Z"'),
    'nonce',          nonce,
    'payload',        payload
  )::text AS envelope
FROM upd
ORDER BY id;
SQL
)

[ -z "$ROWS" ] && exit 0

COUNT=0
IDS=""
while IFS=$'\t' read -r ID ENVELOPE; do
  [ -z "$ID" ] && continue
  TMP="${INBOX_DIR}/.${ID}.json.tmp"
  FINAL="${INBOX_DIR}/${ID}.json"
  printf '%s\n' "$ENVELOPE" > "$TMP"
  chmod 0640 "$TMP"
  mv -f "$TMP" "$FINAL"
  IDS="${IDS:+$IDS, }$ID"
  COUNT=$((COUNT+1))
done <<< "$ROWS"

echo "$(date -u +%FT%TZ) gcg-inbox-poll[$AGENT] delivered=$COUNT" >&2

# Wake the agent via its /hooks/fleet endpoint so it actually processes the new files.
# Without this poke, openclaw never scans workspace/inbox/.
if [ "$COUNT" -gt 0 ]; then
  OPENCLAW_CFG="/opt/gcg/openclaw-${AGENT}/openclaw.json"
  if [ -r "$OPENCLAW_CFG" ]; then
    PORT=$(python3 -c "import json,sys; c=json.load(open(sys.argv[1])); print((c.get('gateway') or {}).get('port') or c.get('port') or '')" "$OPENCLAW_CFG" 2>/dev/null)
    TOKEN=$(python3 -c "import json,sys; c=json.load(open(sys.argv[1])); print((c.get('hooks') or {}).get('token') or '')" "$OPENCLAW_CFG" 2>/dev/null)
    if [ -n "$PORT" ] && [ -n "$TOKEN" ]; then
      MSG="You have ${COUNT} new inbox message(s) at workspace/inbox/ (ids: ${IDS}). Process per /opt/gcg/shared/docs/FLEET_INBOX.md: cat each, act on it, then 'fleet done <id>' and rm the file. Respond in English only."
      # Build JSON payload safely with python (handles quoting)
      BODY=$(python3 -c "import json,sys; print(json.dumps({'message': sys.argv[1]}))" "$MSG")
      curl -fsS --max-time 8 \
        -X POST "http://127.0.0.1:${PORT}/hooks/fleet" \
        -H "Authorization: Bearer ${TOKEN}" \
        -H "Content-Type: application/json" \
        -d "$BODY" \
        >/dev/null 2>&1 \
        && echo "$(date -u +%FT%TZ) gcg-inbox-poll[$AGENT] poked port=${PORT}" >&2 \
        || echo "$(date -u +%FT%TZ) gcg-inbox-poll[$AGENT] poke FAILED port=${PORT}" >&2
    fi
  fi
fi
