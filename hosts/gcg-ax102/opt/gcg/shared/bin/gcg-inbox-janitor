#!/bin/bash
# gcg-inbox-janitor v4 ‚Äî "Useful, not harmful"
#
# Key changes from v3:
#   - REPOKE DOES NOT FLEET SEND. Reset status in place only. No new messages.
#   - Hard caps: repoke ‚â§ 50, cancel ‚â§ 200, digest ‚â§ 25. Runtime guard > 60s ‚Üí abort.
#   - StateDirectory=/var/lib/gcg-inbox-janitor (moved away from ProtectSystem=strict).
#     Use /var/lib/gcg-inbox-janitor/state.json for cooldown persistence.
#   - Daily health digest to Daen, not hourly nag. Human-decision items only to Peter.
#   - Cancelled msg notices: still notify recipient & sender, but via fleet send.
#     (This is intentional ‚Äî a cancel notice is a one-time close-out, not amplification.)
#   - Dry-run mode reports capped counts and ZERO new messages created.
#
# Run via: systemctl start gcg-inbox-janitor.service
# Enable: systemctl enable --now gcg-inbox-janitor.timer
# Dry-run: /opt/gcg/shared/bin/gcg-inbox-janitor --dry-run

set -euo pipefail

# ‚îÄ‚îÄ Config ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
PWD_FILE="/opt/gcg/shared/credentials/db/gcg_fleet.pwd"
PSQL_ARGS=(-h 10.0.0.2 -p 5432 -U gcg_fleet -d gcg_intelligence)
VALID_AGENTS_FILE="/tmp/gcg-valid-agents.txt"
DRY_RUN=false
[[ "${1:-}" == "--dry-run" ]] && DRY_RUN=true

# Sender identity for fleet sends from this script
export FLEET_SENDER=janitor

# ‚îÄ‚îÄ Safety limits ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
MAX_REPOKE=50
MAX_CANCEL=200
MAX_DIGEST=25
MAX_RUNTIME_SEC=60
START_TS=$(date +%s)

# ‚îÄ‚îÄ v5 self-healing loop (wedged-agent recovery) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
STUCK_INPROGRESS_MIN=15              # in_progress older than this w/o completing = wedged
MAX_INPROGRESS_RESET=3               # after this many resets, fail the message
MAX_RESTART=5                        # cap agent process restarts per run (anti-storm)
RESTART_COOLDOWN_SECS=$((30 * 60))   # never restart the same agent more than once / 30 min

# ‚îÄ‚îÄ Helpers ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
_log()  { echo "$(date -u +%FT%TZ) gcg-inbox-janitor v4 $*" >&2; }
_dry()  { $DRY_RUN && _log "[DRY-RUN] $*"; }
_fail() { echo "$*" >&2; exit 1; }

# Abort if runtime exceeded
_runtime_check() {
  local elapsed=$(( $(date +%s) - START_TS ))
  if [ "$elapsed" -ge "$MAX_RUNTIME_SEC" ]; then
    _log "RUNTIME GUARD: ${elapsed}s exceeded ${MAX_RUNTIME_SEC}s limit ‚Äî ABORTING"
    exit 2
  fi
}

# ‚îÄ‚îÄ DB helper ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
PSQL_BASE() { PGPASSWORD=$(tr -d '\r\n' < "$PWD_FILE") psql "${PSQL_ARGS[@]}" -v ON_ERROR_STOP=1 -tA "$@"; }
db_q()   { PSQL_BASE -c "$1" 2>/dev/null || true; }
db_f()   { PSQL_BASE -F $'\t' -c "$1" 2>/dev/null || true; }

# ‚îÄ‚îÄ Cooldown / dedup ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
# State lives in /var/lib/gcg-inbox-janitor/state.json (writable dir per systemd unit).
# Cooldown: 24h for digest items, 6h for per-message alerts.
STATE_DIR="/var/lib/gcg-inbox-janitor"
STATE_FILE="${STATE_DIR}/state.json"
DIGEST_STATE_FILE="${STATE_DIR}/digest-state.json"
COOLDOWN_SECS=$((6 * 3600))         # 6h per-message
DIGEST_COOLDOWN_SECS=$((24 * 3600))  # 24h digest

mkdir -p "$STATE_DIR"

_ensure_state() {
  [ -f "$STATE_FILE" ] || echo '{}' > "$STATE_FILE"
  [ -f "$DIGEST_STATE_FILE" ] || echo '{}' > "$DIGEST_STATE_FILE"
}

# should_alert <key>  ‚Üí rc 0 = fire (and record timestamp), rc 1 = suppressed
should_alert() {
  local key="$1" now last
  _ensure_state
  now=$(date -u +%s)
  last=$(jq -r --arg k "$key" '.[$k] // empty' "$STATE_FILE" 2>/dev/null)
  if [ -n "$last" ] && [ $((now - last)) -lt "$COOLDOWN_SECS" ]; then
    _log "SUPPRESS $key ‚Äî last alert $((now - last))s ago (< ${COOLDOWN_SECS}s cooldown)"
    return 1
  fi
  if ! $DRY_RUN; then
    local tmp; tmp=$(mktemp)
    jq --arg k "$key" --argjson t "$now" '.[$k]=$t' "$STATE_FILE" > "$tmp" 2>/dev/null \
      && cp "$tmp" "$STATE_FILE" 2>/dev/null || true
    rm -f "$tmp"
  fi
  return 0
}

# should_digest <key>  ‚Äî 24h cooldown for digest-level surfacing
should_digest() {
  local key="$1" now last
  _ensure_state
  now=$(date -u +%s)
  last=$(jq -r --arg k "$key" '.[$k] // empty' "$DIGEST_STATE_FILE" 2>/dev/null)
  if [ -n "$last" ] && [ $((now - last)) -lt "$DIGEST_COOLDOWN_SECS" ]; then
    _log "DIGEST_SUPPRESS $key ‚Äî last digest $((now - last))s ago (< ${DIGEST_COOLDOWN_SECS}s cooldown)"
    return 1
  fi
  if ! $DRY_RUN; then
    local tmp; tmp=$(mktemp)
    jq --arg k "$key" --argjson t "$now" '.[$k]=$t' "$DIGEST_STATE_FILE" > "$tmp" 2>/dev/null \
      && cp "$tmp" "$DIGEST_STATE_FILE" 2>/dev/null || true
    rm -f "$tmp"
  fi
  return 0
}

# ‚îÄ‚îÄ Build valid agent list ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
get_valid_agents() {
  systemctl list-units --type=service --all 2>/dev/null \
    | grep 'gcg-inbox-poller@' \
    | sed 's/.*gcg-inbox-poller@\([^.]*\)\..*/\1/' \
    | sort -u
}

# ‚îÄ‚îÄ 1. Orphaned-recipient detection + routing ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
# Peter's rules: peter/pierre ‚Üí human (surfaced to digest only), cowork ‚Üí hold,
#   mnemo ‚Üí mnemosyne, anything else ‚Üí cancel.
handle_orphans() {
  local count=0 human_count=0 cowork_count=0 corrected_count=0 cancelled_count=0
  local human_items=""

  local orphans
  orphans=$(db_q "
    SELECT id, sender, recipient, status, issued_at
    FROM agent_messages
    WHERE status NOT IN ('done','cancelled','failed')
      AND recipient NOT IN ($(sed "s/ /','/g; s/^/'/; s/$/'/" <<< "$(get_valid_agents | tr '\n' ' ')")
    ORDER BY id;
  " 2>/dev/null) || orphans=""

  if [ -z "$orphans" ]; then
    _log "orphans=0"
    return
  fi

  while IFS='|' read -r id sender recipient status issued_at; do
    [ -z "$id" ] && continue
    count=$((count + 1))
    _runtime_check

    case "$recipient" in
      peter|pierre)
        human_count=$((human_count + 1))
        human_items+="  #${id} ${recipient} ‚Üê ${sender} (${status}, ${issued_at})\n"
        _log "ORPHAN_HUMAN id=$id recipient=$recipient ‚Äî surfaced to human-digest"
        ;;
      cowork)
        cowork_count=$((cowork_count + 1))
        _log "ORPHAN_COWORK id=$id ‚Äî valid-dormant, held"
        ;;
      mnemo)
        corrected_count=$((corrected_count + 1))
        _log "ORPHAN_CORRECT id=$id mnemo‚Üímnemosyne"
        if ! $DRY_RUN; then
          db_q "UPDATE agent_messages SET recipient='mnemosyne' WHERE id=$id AND status NOT IN ('done','cancelled','failed');"
        fi
        ;;
      *)
        cancelled_count=$((cancelled_count + 1))
        _log "ORPHAN_CANCEL id=$id recipient=$recipient"
        if ! $DRY_RUN; then
          db_q "UPDATE agent_messages SET status='cancelled', done_at=NOW(), blocked_reason='orphaned recipient, no poller' WHERE id=$id AND status NOT IN ('done','cancelled','failed');"
        fi
        ;;
    esac
  done <<< "$orphans"

  _log "orphans=$count human=$human_count cowork=$cowork_count corrected=$corrected_count cancelled=$cancelled_count"

  # Human-digest to Daen (24h cooldown on the ORPHAN_HUMAN digest key)
  if [ "$human_count" -gt 0 ] && should_digest "orphan_human_$(( $(date -u +%s) / 86400 ))" && ! $DRY_RUN; then
    local msg="Inbox Janitor: ${human_count} human-targeted messages found in orphan scanning ‚Äî relay:\n${human_items}"
    /opt/gcg/shared/bin/fleet send daen "$msg" 2>/dev/null || _log "WARN: failed to fleet send orphan human digest"
  fi
}

# ‚îÄ‚îÄ 2. Repoke acked/delivered without start >1h ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
# KEY RULE: repoke DOES NOT create new messages. Reset status in place only.
# If deliver_count > threshold: cancel instead.
# If cancel needed: we DO notify recipient & sender (one-time close-out), capped.
handle_acked_stale() {
  local rows
  rows=$(db_f "
    SELECT id, recipient, sender, deliver_count FROM agent_messages
    WHERE status IN ('delivered','acked')
      AND acked_at < NOW() - INTERVAL '1 hour'
      AND started_at IS NULL
    ORDER BY id
    LIMIT $((MAX_REPOKE + MAX_CANCEL));
  " 2>/dev/null) || rows=""

  local count=0 repoke_count=0 cancel_count=0 repoke_sent=0 cancel_sent=0
  while IFS=$'\t' read -r id recipient sender deliver_count; do
    [ -z "$id" ] && continue
    count=$((count + 1))
    _runtime_check

    if [ "${deliver_count:-0}" -ge 6 ]; then
      # Cancel ‚Äî 6+ delivery attempts over multiple hours, agent truly isn't picking up.
      # Raised from 2 ‚Üí 6 (v4.1, 2026-06-15) to match poller's zombie guard at 5.
      # The old deliver_count‚â•2 was triggered by the janitor's own repokes:
      # janitor repoke ‚Üí deliver_count=3, next poller reclaim ‚Üí deliver_count=4,
      # janitor runs again ‚Üí deliver_count=5, sees ‚â•2 ‚Üí kills it. Race condition.
      if [ "$cancel_count" -ge "$MAX_CANCEL" ]; then
        _log "CANCEL_LIMIT reached ($MAX_CANCEL) ‚Äî skipping id=$id"
        continue
      fi
      cancel_count=$((cancel_count + 1))
      _log "CANCEL id=$id recipient=$recipient sender=$sender deliver_count=$deliver_count"

      if ! $DRY_RUN; then
        db_q "UPDATE agent_messages SET status='cancelled', done_at=NOW(), blocked_reason='abandoned after ${deliver_count} deliveries. Janitor auto-cancel.' WHERE id=$id AND status IN ('delivered','acked');"

        # One-time close-out to recipient (this IS a new message, but it's
        # a cancel confirmation ‚Äî one per cancelled row, not amplification)
        cancel_sent=$((cancel_sent + 1))
        /opt/gcg/shared/bin/fleet send "$recipient" "‚öÝÔ∏è Inbox msg #$id ‚Äî cancelled (delivered ${deliver_count}x, never started)." 2>/dev/null || true
        if [ -n "$sender" ]; then
          /opt/gcg/shared/bin/fleet send "$sender" "‚öÝÔ∏è Your msg #$id to ${recipient} ‚Äî cancelled (abandoned after ${deliver_count} deliveries)." 2>/dev/null || true
        fi
      fi
    else
      # Repoke ‚Äî reset to pending WITHOUT creating a new message
      if [ "$repoke_count" -ge "$MAX_REPOKE" ]; then
        _log "REPOKE_LIMIT reached ($MAX_REPOKE) ‚Äî skipping id=$id"
        continue
      fi
      repoke_count=$((repoke_count + 1))
      _log "REPOKE id=$id recipient=$recipient sender=$sender deliver_count=${deliver_count:-0} ‚Äî resetting to pending (NO new message created)"

      if ! $DRY_RUN; then
        db_q "UPDATE agent_messages SET status='pending', acked_at=NULL, deliver_count=deliver_count+1 WHERE id=$id AND status IN ('delivered','acked');"
        # NO fleet send here ‚Äî the poller will re-deliver on its own.
        # This is the amplification fix: repoke = status change only, zero new rows.
      fi
    fi
  done <<< "$rows"

  _log "acked_stale_total=$count repoke=$repoke_count cancel=$cancel_count"
}

# ‚îÄ‚îÄ 3. Wedged-agent recovery: stuck in_progress ‚Üí reset msg + restart agent ‚îÄ‚îÄ
# A message claimed (in_progress) but not completing past STUCK_INPROGRESS_MIN is
# the signature of a wedged agent process (proven 2026-06-13: Talos held good creds
# but stopped completing turns; the fix was restart + reset the orphaned claim).
# This automates that exact fix: reset the orphaned message to pending (pure DB,
# works under the sandbox) AND restart the owning agent (deduped 30m, capped, best-effort).
RESTART_STATE="${STATE_DIR}/restart-state.json"
_restart_allowed() {  # rc0 = allowed, rc1 = on cooldown ‚Äî READ ONLY (no state write)
  local agent="$1" now last
  [ -f "$RESTART_STATE" ] || echo '{}' > "$RESTART_STATE"
  now=$(date -u +%s)
  last=$(jq -r --arg k "$agent" '.[$k] // empty' "$RESTART_STATE" 2>/dev/null)
  [ -n "$last" ] && [ $((now - last)) -lt "$RESTART_COOLDOWN_SECS" ] && return 1
  return 0
}
_record_restart() {  # called ONLY after an actual successful restart
  local agent="$1" now; now=$(date -u +%s)
  [ -f "$RESTART_STATE" ] || echo '{}' > "$RESTART_STATE"
  jq --arg k "$agent" --arg t "$now" '.[$k]=($t|tonumber)' "$RESTART_STATE" > "${RESTART_STATE}.tmp" 2>/dev/null && mv "${RESTART_STATE}.tmp" "$RESTART_STATE"
}

handle_wedged_inprogress() {
  local rows
  rows=$(db_f "
    SELECT id, recipient, sender, COALESCE(deliver_count,0) AS dc
    FROM agent_messages
    WHERE status = 'in_progress'
      AND started_at < NOW() - INTERVAL '${STUCK_INPROGRESS_MIN} minutes'
    ORDER BY id
    LIMIT 100;
  " 2>/dev/null) || rows=""

  local count=0 reset_count=0 fail_count=0 restart_count=0
  declare -A seen_agent
  while IFS=$'\t' read -r id recipient sender dc; do
    [ -z "$id" ] && continue
    count=$((count + 1))
    _runtime_check

    # (a) Restart the wedged agent ‚Äî once per run per agent, valid-agent only, capped, 30m cooldown
    if [ -n "$recipient" ] && [ -z "${seen_agent[$recipient]:-}" ]; then
      seen_agent[$recipient]=1
      if systemctl cat "openclaw-${recipient}.service" >/dev/null 2>&1 && [ "$restart_count" -lt "$MAX_RESTART" ]; then
        if _restart_allowed "$recipient"; then
          restart_count=$((restart_count + 1))
          _log "WEDGE_RESTART agent=$recipient (msg #$id stuck in_progress >${STUCK_INPROGRESS_MIN}m) ‚Äî restarting openclaw-${recipient}.service"
          if ! $DRY_RUN; then
            if systemctl restart "openclaw-${recipient}.service" 2>/dev/null; then
              _record_restart "$recipient"
            else
              _log "WARN: restart openclaw-${recipient}.service failed (check janitor sandbox perms)"
            fi
          fi
        else
          _log "WEDGE_RESTART_SUPPRESS agent=$recipient ‚Äî restarted <${RESTART_COOLDOWN_SECS}s ago"
        fi
      fi
    fi

    # (b) Reset the orphaned message (bounded retries) so the fresh process reclaims it
    if [ "${dc:-0}" -ge "$MAX_INPROGRESS_RESET" ]; then
      fail_count=$((fail_count + 1))
      _log "WEDGE_FAIL id=$id recipient=$recipient ‚Äî exceeded ${MAX_INPROGRESS_RESET} resets, marking failed"
      if ! $DRY_RUN; then
        db_q "UPDATE agent_messages SET status='failed', done_at=NOW(), blocked_reason='auto-failed: stuck in_progress >${STUCK_INPROGRESS_MIN}m, exceeded ${MAX_INPROGRESS_RESET} resets (janitor v5)' WHERE id=$id AND status='in_progress';"
      fi
    else
      reset_count=$((reset_count + 1))
      _log "WEDGE_RESET id=$id recipient=$recipient deliver_count=${dc:-0} ‚Äî reset to pending for reprocessing"
      if ! $DRY_RUN; then
        db_q "UPDATE agent_messages SET status='pending', started_at=NULL, acked_at=NULL, deliver_count=COALESCE(deliver_count,0)+1 WHERE id=$id AND status='in_progress';"
      fi
    fi
  done <<< "$rows"

  _log "wedged_inprogress_total=$count reset=$reset_count failed=$fail_count restarts=$restart_count"
}

# ‚îÄ‚îÄ 4. Auto-resolve: blocked items whose blocker cleared ‚Üí unblock ‚îÄ
# If a msg is blocked but the blocker is no longer blocked, auto-reset to pending.
handle_blocked_auto_resolve() {
  local rows
  rows=$(db_f "
    SELECT id, recipient, COALESCE(blocked_reason, '') AS reason
    FROM agent_messages
    WHERE status = 'blocked'
    ORDER BY id
    LIMIT 200;
  " 2>/dev/null) || rows=""

  local count=0 resolved=0
  while IFS=$'\t' read -r id recipient reason; do
    [ -z "$id" ] && continue
    count=$((count + 1))
    _runtime_check

    # Check if blocker is still blocked: if blocked_reason references a msg id,
    # check if that msg is still blocked. Otherwise simple auto-resolve not possible.
    local blocker_id
    blocker_id=$(echo "$reason" | grep -oP 'msg #\K\d+' || true)
    if [ -n "$blocker_id" ]; then
      local blocker_status
      blocker_status=$(db_q "SELECT status FROM agent_messages WHERE id=$blocker_id;" 2>/dev/null | head -1)
      if [ "$blocker_status" != "blocked" ] && [ -n "$blocker_status" ]; then
        resolved=$((resolved + 1))
        _log "AUTO_RESOLVE id=$id ‚Äî blocker #$blocker_status is now '${blocker_status}', unblocking"
        if ! $DRY_RUN; then
          db_q "UPDATE agent_messages SET status='pending', blocked_reason=NULL WHERE id=$id AND status='blocked';"
        fi
      fi
    fi
  done <<< "$rows"

  _log "blocked_auto_resolve_total=$count resolved=$resolved"
}

# ‚îÄ‚îÄ 5. Digest blocked to Daen (DAILY, not hourly) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
# Uses 24h cooldown on the digest-level key. Includes auto-resolved counts.
handle_blocked_digest() {
  local rows
  rows=$(db_f "
    SELECT id, sender, recipient, COALESCE(blocked_reason, 'no reason') AS reason
    FROM agent_messages
    WHERE status = 'blocked'
    ORDER BY blocked_at DESC
    LIMIT $MAX_DIGEST;
  " 2>/dev/null) || rows=""

  local count=0 digest_items=""
  while IFS=$'\t' read -r id sender recipient reason; do
    [ -z "$id" ] && continue
    count=$((count + 1))
    should_alert "blocked:$id" || continue
    digest_items+="  #${id} ${recipient} ‚Üê ${sender}: ${reason:0:200}\n"
  done <<< "$rows"

  _log "blocked_digest_new=$count"

  if [ -n "$digest_items" ] && should_digest "blocked_digest_$(( $(date -u +%s) / 86400 ))" && ! $DRY_RUN; then
    # Classify into human-decision vs agent-blocked
    local human_items=""
    local agent_items=""
    while IFS= read -r line; do
      [ -z "$line" ] && continue
      if echo "$line" | grep -qiE '(peter|pierre|awaiting.*human|decide|approve)'; then
        human_items+="${line}\n"
      else
        agent_items+="${line}\n"
      fi
    done <<< "$(echo -e "$digest_items")"

    # Agent-blocked items ‚Üí daily digest to Daen
    if [ -n "$agent_items" ]; then
      local agent_msg="Inbox Janitor ‚Äî Daily Digest\n# Agent-blocked items:\n${agent_items}"
      /opt/gcg/shared/bin/fleet send daen "$agent_msg" 2>/dev/null || _log "WARN: failed to fleet send agent digest to daen"
    fi

    # Human-decision items ‚Üí one decision card to Peter (24h deduped)
    if [ -n "$human_items" ]; then
      local human_msg="Inbox Janitor ‚Äî Human Decision Needed\n# Items requiring your review:\n${human_items}"
      /opt/gcg/shared/bin/fleet send daen "$human_msg" 2>/dev/null || _log "WARN: failed to fleet send human-decision digest to daen"
      _log "HUMAN_DECISION_ITEMS surfaced to Daen for relay to Peter"
    fi
  fi
}

# ‚îÄ‚îÄ 6. Status histogram ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
print_histogram() {
  local hist
  hist=$(db_q "SELECT status, count(*) FROM agent_messages GROUP BY status ORDER BY status;" 2>/dev/null)
  while IFS='|' read -r status cnt; do
    [ -z "$status" ] && continue
    _log "histogram $status=$cnt"
  done <<< "$hist"

  local size
  size=$(db_q "SELECT count(*) FROM agent_messages;" 2>/dev/null)
  _log "total_rows=$size"
}

# ‚îÄ‚îÄ 7. Daily health digest (one line to Daen) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
# Only on dry-run we log it. In live mode, if not supressed, send one-liner.
daily_health_digest() {
  if ! should_digest "health_$(( $(date -u +%s) / 86400 ))"; then
    _log "health_digest_suppressed ‚Äî already sent today"
    return
  fi

  local bus_depth oldest_open auto_resolved_count cancelled_count repoked_count
  bus_depth=$(db_q "SELECT count(*) FROM agent_messages WHERE status NOT IN ('done','cancelled','failed');" 2>/dev/null | head -1)
  oldest_open=$(db_q "SELECT MIN(issued_at) FROM agent_messages WHERE status NOT IN ('done','cancelled','failed');" 2>/dev/null | head -1)
  oldest_open=${oldest_open:-(none)}

  _log "health_digest: bus=$bus_depth oldest=$oldest_open"

  if ! $DRY_RUN; then
    local line="üßπ Inbox Health: ${bus_depth} active msgs, oldest ${oldest_open}"
    /opt/gcg/shared/bin/fleet send daen "$line" 2>/dev/null || _log "WARN: failed to fleet send health digest"
  fi
}

# ‚îÄ‚îÄ Main ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
_log "=== starting (dry_run=$DRY_RUN) ==="

print_histogram

handle_orphans
_runtime_check

handle_acked_stale
_runtime_check

handle_wedged_inprogress
_runtime_check

handle_blocked_auto_resolve
_runtime_check

handle_blocked_digest
_runtime_check

daily_health_digest

print_histogram

_log "=== complete ==="
