#!/usr/bin/env bash
# /opt/gcg/shared/bin/memory — GCG Memory CLI dispatcher
# Rebuilt 2026-05-20. No plaintext secrets. Reads env only.
# Usage: memory <recall|capture|research|--help> [args...]

set -euo pipefail

PYTHON=/opt/gcg/shared/venv/bin/python3
RECALL_V3=/opt/gcg/shared/gcg_tools/recall_v3.py
EMBED_V2=/opt/gcg/shared/gcg_tools/embed_v2.py
SCRIPT_VERSION="2026-05-20"

# ── Help ───────────────────────────────────────────────────────────────────────
_help_main() {
  cat <<EOF
memory $SCRIPT_VERSION — GCG memory CLI

Subcommands:
  recall   "<query>"   Query memory (hybrid vector+graph)
  capture  "<text>"    Write a memory to pgvector
  research "<query>"   Broad recall (higher top-k, all tiers)

Options:
  --help    Show this help

recall flags:
  --agent <name>    Agent context (sources env from /run/openclaw-<name>/env if needed)
  --top-k N         Number of results (default: 10)
  --json            Output JSON
  --tier0-only      Tier-0 namespace only

capture flags:
  --agent <name>    Agent name (required; written into memories table)
  --source-type X   Source type (default: conversation)

research flags:
  Same as recall. Uses top-k 20 and all tiers by default.
EOF
}

_help_recall() {
  cat <<EOF
memory recall "<query>" [options]
  --agent <name>   Agent name (for env sourcing + recall log)
  --top-k N        Results count (default: 10)
  --json           Output JSON
  --tier0-only     Only Tier-0 namespace
EOF
}

_help_capture() {
  cat <<EOF
memory capture "<text>" [options]
  --agent <name>      Agent name (default: unknown)
  --source-type X     Source type (default: conversation)
EOF
}

_help_research() {
  cat <<EOF
memory research "<query>" [options]
  Same flags as recall. Defaults to --top-k 20 with all tiers.
EOF
}

# ── Env loader ────────────────────────────────────────────────────────────────
# If key env vars are missing and --agent was given, source that agent's env.
_maybe_source_agent_env() {
  local agent="${1:-}"
  if [[ -n "$agent" && -f "/run/openclaw-${agent}/env" ]]; then
    # shellcheck disable=SC1090
    set +u
    source "/run/openclaw-${agent}/env"
    set -u
  fi
  # Bridge: agents export GEMINI_API_KEY; embed_v2 checks GOOGLE_AI_API_KEY
  if [[ -z "${GOOGLE_AI_API_KEY:-}" && -n "${GEMINI_API_KEY:-}" ]]; then
    export GOOGLE_AI_API_KEY="$GEMINI_API_KEY"
  fi
  # Also bridge GOOGLE_API_KEY
  if [[ -z "${GOOGLE_AI_API_KEY:-}" && -n "${GOOGLE_API_KEY:-}" ]]; then
    export GOOGLE_AI_API_KEY="$GOOGLE_API_KEY"
  fi
}

# ── Preflight checks ──────────────────────────────────────────────────────────
_preflight() {
  local agent="${1:-}"
  _maybe_source_agent_env "$agent"

  local missing=()
  [[ -z "${GCG_DB_PASSWORD:-}" ]] && missing+=("GCG_DB_PASSWORD")
  [[ -z "${GOOGLE_AI_API_KEY:-}${GEMINI_API_KEY:-}${GOOGLE_API_KEY:-}" ]] && missing+=("GEMINI_API_KEY / GOOGLE_AI_API_KEY")

  if [[ ${#missing[@]} -gt 0 ]]; then
    echo "ERROR: Missing required env vars: ${missing[*]}" >&2
    if [[ -n "$agent" ]]; then
      echo "  Tried sourcing /run/openclaw-${agent}/env" >&2
    else
      echo "  Tip: pass --agent <name> to auto-source env" >&2
    fi
    exit 1
  fi
}

# ── DB reachability ───────────────────────────────────────────────────────────
_check_db() {
  local host="${GCG_DB_HOST:-10.0.0.2}"
  local port="${GCG_DB_PORT:-5432}"
  local user="${GCG_DB_USER:-gcg_admin}"
  local dbname="${GCG_DB_NAME:-gcg_intelligence}"

  if ! pg_isready -h "$host" -p "$port" -U "$user" -d "$dbname" -t 2 >/dev/null 2>&1; then
    echo "ERROR: DB unreachable at ${host}:${port} (pg_isready timeout)" >&2
    exit 1
  fi
}

# ── Audit log ─────────────────────────────────────────────────────────────────
# Writes to memory_recall_log (for recall/research) or memory_write_log (for capture).
# Never blocks the actual command on failure.
_audit_recall() {
  local agent="${1:-unknown}" query="${2:-}" exit_code="${3:-0}"
  local query_trunc="${query:0:500}"
  local host="${GCG_DB_HOST:-10.0.0.2}" port="${GCG_DB_PORT:-5432}"
  local user="${GCG_DB_USER:-gcg_admin}" dbname="${GCG_DB_NAME:-gcg_intelligence}"

  PGPASSWORD="${GCG_DB_PASSWORD}" psql \
    -h "$host" -p "$port" -U "$user" -d "$dbname" \
    -c "INSERT INTO public.memory_recall_log (agent_name, query, memory_ids, metadata)
        VALUES ('${agent}', \$\$${query_trunc}\$\$, '{}', jsonb_build_object(
          'caller', '$(whoami 2>/dev/null || echo unknown)',
          'subcmd', 'recall',
          'exit_code', ${exit_code},
          'cli_version', '${SCRIPT_VERSION}'
        ))" \
    >/dev/null 2>&1 \
    || echo "WARN: audit log insert failed (memory_recall_log)" >&2
}

_audit_capture() {
  local agent="${1:-unknown}" input_trunc="${2:-}" exit_code="${3:-0}"
  local host="${GCG_DB_HOST:-10.0.0.2}" port="${GCG_DB_PORT:-5432}"
  local user="${GCG_DB_USER:-gcg_admin}" dbname="${GCG_DB_NAME:-gcg_intelligence}"

  PGPASSWORD="${GCG_DB_PASSWORD}" psql \
    -h "$host" -p "$port" -U "$user" -d "$dbname" \
    -c "INSERT INTO public.memory_write_log (agent_id, action, metadata)
        VALUES ('${agent}', 'create', jsonb_build_object(
          'caller', '$(whoami 2>/dev/null || echo unknown)',
          'subcmd', 'capture',
          'input_preview', \$\$${input_trunc}\$\$,
          'exit_code', ${exit_code},
          'cli_version', '${SCRIPT_VERSION}'
        ))" \
    >/dev/null 2>&1 \
    || echo "WARN: audit log insert failed (memory_write_log)" >&2
}

# ── Subcommand: recall ────────────────────────────────────────────────────────
cmd_recall() {
  local query="" agent="" top_k=10 json_flag="" tier0_flag=""
  local extra_args=()

  # Parse args
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h)       _help_recall; exit 0 ;;
      --agent)         agent="$2"; shift 2 ;;
      --agent=*)       agent="${1#--agent=}"; shift ;;
      --top-k|--top_k) top_k="$2"; shift 2 ;;
      --top-k=*|--top_k=*) top_k="${1#*=}"; shift ;;
      --json)          json_flag="--json"; shift ;;
      --tier0-only)    tier0_flag="--tier0-only"; shift ;;
      -*)              extra_args+=("$1"); shift ;;
      *)
        if [[ -z "$query" ]]; then query="$1"; shift
        else extra_args+=("$1"); shift; fi
        ;;
    esac
  done

  if [[ -z "$query" ]]; then
    echo "ERROR: recall requires a query string" >&2
    _help_recall; exit 1
  fi

  _preflight "$agent"
  _check_db

  local exit_code=0
  $PYTHON "$RECALL_V3" "$query" --top_k "$top_k" ${json_flag} ${tier0_flag} "${extra_args[@]+"${extra_args[@]}"}" || exit_code=$?

  _audit_recall "$agent" "$query" "$exit_code"
  exit $exit_code
}

# ── Subcommand: capture ───────────────────────────────────────────────────────
cmd_capture() {
  local input="" agent="unknown" source_type="conversation"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h)           _help_capture; exit 0 ;;
      --agent)             agent="$2"; shift 2 ;;
      --agent=*)           agent="${1#--agent=}"; shift ;;
      --source-type|--source_type) source_type="$2"; shift 2 ;;
      --source-type=*|--source_type=*) source_type="${1#*=}"; shift ;;
      *)
        if [[ -z "$input" ]]; then input="$1"; shift
        else echo "ERROR: unexpected arg: $1" >&2; exit 1; fi
        ;;
    esac
  done

  if [[ -z "$input" ]]; then
    echo "ERROR: capture requires an input string" >&2
    _help_capture; exit 1
  fi

  _preflight "$agent"
  _check_db

  local input_trunc="${input:0:500}"
  local exit_code=0

  $PYTHON - "$input" "$agent" "$source_type" <<'PYEOF' || exit_code=$?
import sys
import os
for p in ("/opt/gcg/shared/gcg_tools", "/opt/gcg/shared"):
    if p not in sys.path:
        sys.path.insert(0, p)
from embed_v2 import embed_text
text, agent, source_type = sys.argv[1], sys.argv[2], sys.argv[3]
rows = embed_text(
    text=text,
    source_path="memory-cli-capture",
    source_type=source_type,
    agent_name=agent,
    scope_type="agent_private",
    importance="normal",
)
print(f"[capture] {rows} row(s) written to memories (agent={agent}, source_type={source_type})")
PYEOF

  _audit_capture "$agent" "$input_trunc" "$exit_code"
  exit $exit_code
}

# ── Subcommand: research ──────────────────────────────────────────────────────
# No research mode in recall_v3 — route to recall with wider top-k + all tiers.
cmd_research() {
  local query="" agent="" top_k=20 json_flag=""
  local extra_args=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h)       _help_research; exit 0 ;;
      --agent)         agent="$2"; shift 2 ;;
      --agent=*)       agent="${1#--agent=}"; shift ;;
      --top-k|--top_k) top_k="$2"; shift 2 ;;
      --top-k=*|--top_k=*) top_k="${1#*=}"; shift ;;
      --json)          json_flag="--json"; shift ;;
      -*)              extra_args+=("$1"); shift ;;
      *)
        if [[ -z "$query" ]]; then query="$1"; shift
        else extra_args+=("$1"); shift; fi
        ;;
    esac
  done

  if [[ -z "$query" ]]; then
    echo "ERROR: research requires a query string" >&2
    _help_research; exit 1
  fi

  _preflight "$agent"
  _check_db

  # Note: recall_v3 has no research mode. Routing to recall with --all-tiers + wider top-k.
  local exit_code=0
  $PYTHON "$RECALL_V3" "$query" --top_k "$top_k" --all-tiers ${json_flag} "${extra_args[@]+"${extra_args[@]}"}" || exit_code=$?

  _audit_recall "$agent" "$query" "$exit_code"
  exit $exit_code
}

# ── Dispatch ──────────────────────────────────────────────────────────────────
if [[ $# -eq 0 ]]; then
  _help_main; exit 0
fi

case "$1" in
  recall)   shift; cmd_recall "$@" ;;
  capture)  shift; cmd_capture "$@" ;;
  research) shift; cmd_research "$@" ;;
  --help|-h|help) _help_main; exit 0 ;;
  *)
    echo "ERROR: unknown subcommand '$1'" >&2
    echo "Run: memory --help" >&2
    exit 1
    ;;
esac
