#!/bin/bash
# Claude Interactive TMUX Bridge v45 — paste-buffer + full scrollback diff
# TESTED AND WORKING on sub-peter with bypass accepted.
set -euo pipefail

MODEL="sonnet"
PROMPT=""
TIMEOUT=180
SESS="bridge-isolated"
HOME_DIR="/opt/gcg/claude-profiles/sub-peter"

while [[ $# -gt 0 ]]; do
    case "$1" in
        --model) MODEL="$2"; shift 2 ;;
        --prompt) PROMPT="$2"; shift 2 ;;
        *) shift ;;
    esac
done

case "$MODEL" in
    sonnet*) M="claude-sonnet-4-6" ;;
    opus*) M="claude-opus-4-8" ;;
    haiku*) M="claude-haiku-4-5" ;;
    fable*) M="claude-fable-5" ;;
    *) M="claude-sonnet-4-6" ;;
esac

# Ensure warm session
if ! tmux has-session -t "$SESS" 2>/dev/null; then
    tmux new-session -d -s "$SESS" -c /opt/gcg/shared -x 200 -y 50
    tmux set-option -t "$SESS" history-limit 50000
    tmux send-keys -t "$SESS" "export HOME=$HOME_DIR IS_SANDBOX=1 DISABLE_AUTOUPDATER=1" Enter
    sleep 0.5
    tmux send-keys -t "$SESS" "claude --model $M" Enter
    sleep 15
fi

# Capture before
BEFORE_FILE=$(mktemp)
tmux capture-pane -t "$SESS" -p -S -5000 > "$BEFORE_FILE" 2>/dev/null || true

# Send prompt via paste-buffer (binary safe, no quote issues)
printf '%s' "$PROMPT" | tmux load-buffer -
tmux paste-buffer -p -t "$SESS"
sleep 0.3
tmux send-keys -t "$SESS" Enter

# Wait for Claude response
elapsed=0; STABLE=0
while [[ $elapsed -lt $TIMEOUT ]]; do
    sleep 2; elapsed=$((elapsed + 2))
    P=$(tmux capture-pane -t "$SESS" -p -S -20 2>/dev/null || true)
    if echo "$P" | grep -qiE "Cogitated|Cooked|Crunched|Sautéed|Churned|Brewed|Worked"; then
        STABLE=0; continue
    fi
    if echo "$P" | grep -q "❯"; then
        STABLE=$((STABLE + 1))
        [ $STABLE -ge 3 ] && break
    else
        STABLE=0
    fi
done

# Capture after
AFTER_FILE=$(mktemp)
tmux capture-pane -t "$SESS" -p -S -5000 > "$AFTER_FILE" 2>/dev/null || true

# Extract: find lines in AFTER that aren't in BEFORE, that look like Claude responses
# Claude responses start with "● " — extract those
RESULT=$(diff "$BEFORE_FILE" "$AFTER_FILE" 2>/dev/null | grep "^>" | sed 's/^> //' | grep -E "^(●|  )" | grep -v "❯\|✻\|⏵\|tmux\|scroll\|PgUp\|? for\|───\|Enter to\|bypass\|Tips for\|What.s new\|Added \`\|Fixed the\|/release\|Meet Fable\|Included in\|Welcome back\|Run /init" | head -20 | paste -sd' ' - | sed 's/● //g; s/  */ /g' | xargs 2>/dev/null)

if [[ -z "${RESULT// }" ]]; then
    RESULT="No response"
fi

rm -f "$BEFORE_FILE" "$AFTER_FILE"
printf '%s' "$RESULT" | python3 -c 'import sys,json; print(json.dumps({"type":"result","result":sys.stdin.read()}))'
