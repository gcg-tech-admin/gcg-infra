#!/bin/bash
# gcg-secret-bootstrap.sh — runs as systemd ExecStartPre
# Reads encrypted credentials from $CREDENTIALS_DIRECTORY (tmpfs, root-0400)
# Fetches per-agent Anthropic key via 1Password CLI
# Writes runtime env file to /run/openclaw-${AGENT}/env (tmpfs, root-0600)
# Plaintext NEVER on persistent disk.
set -e

AGENT="${1:?agent name required}"
RUNTIME_DIR="/run/openclaw-${AGENT}"
mkdir -p "$RUNTIME_DIR"
chmod 700 "$RUNTIME_DIR"

if [ -z "$CREDENTIALS_DIRECTORY" ]; then
  echo "ERROR: \$CREDENTIALS_DIRECTORY not set — must run from systemd with LoadCredentialEncrypted=" >&2
  exit 2
fi

# 1. DB env (multi-line: GCG_DB_HOST, GCG_DB_PORT, GCG_DB_NAME, GCG_DB_USER, GCG_DB_PASSWORD, PGPASSWORD)
if [ -r "$CREDENTIALS_DIRECTORY/db-env" ]; then
  DB_ENV=$(cat "$CREDENTIALS_DIRECTORY/db-env")
else
  DB_ENV=""
fi

# 2. Gateway tokens — pick this agent's line from the full file (GATEWAY_TOKEN_<AGENT_UPPER>)
GW_LINE=""
if [ -r "$CREDENTIALS_DIRECTORY/gateway-env" ]; then
  AGENT_UPPER=$(echo "$AGENT" | tr '[:lower:]' '[:upper:]')
  GW_LINE=$(grep "^GATEWAY_TOKEN_${AGENT_UPPER}=" "$CREDENTIALS_DIRECTORY/gateway-env" || true)
fi

# 3. OP Service Account token — needed only for this ExecStartPre run
if [ ! -r "$CREDENTIALS_DIRECTORY/op-sa-token" ]; then
  echo "ERROR: op-sa-token credential not found" >&2
  exit 3
fi
OP_TOKEN=$(cat "$CREDENTIALS_DIRECTORY/op-sa-token")

# 4. Map agent → 1Password item name
case "$AGENT" in
  daen)   ITEM="Anthropic Daen" ;;
  nik)    ITEM="Anthropic Nik" ;;
  talos)  ITEM="Anthropic Talos" ;;
  marcus) ITEM="Anthropic Marcus" ;;
  kira)   ITEM="Anthropic Kira" ;;
  kenji)  ITEM="Anthropic Kenji" ;;
  viktor) ITEM="Anthropic Viktor" ;;
  anna)   ITEM="Anthropic Anna - CMO STR" ;;
  vera)   ITEM="Anthropic Vera - CMO RE" ;;
  *)
    # Capitalize first letter as default
    UP=$(echo "${AGENT:0:1}" | tr '[:lower:]' '[:upper:]')
    ITEM="Anthropic ${UP}${AGENT:1}"
    ;;
esac

# 5. Fetch the Anthropic key
ANTHROPIC_KEY=$(OP_SERVICE_ACCOUNT_TOKEN="$OP_TOKEN" op read "op://GCG Agent Fleet/${ITEM}/credential" 2>/dev/null || true)

# 6. Compose runtime env file on tmpfs only
{
  [ -n "$DB_ENV" ]      && echo "$DB_ENV"
  [ -n "$GW_LINE" ]     && echo "$GW_LINE"
  [ -n "$ANTHROPIC_KEY" ] && echo "ANTHROPIC_API_KEY=$ANTHROPIC_KEY"
} > "$RUNTIME_DIR/env"
chmod 600 "$RUNTIME_DIR/env"

echo "gcg-secret-bootstrap: $AGENT runtime env written ($(wc -l < "$RUNTIME_DIR/env") lines)"
