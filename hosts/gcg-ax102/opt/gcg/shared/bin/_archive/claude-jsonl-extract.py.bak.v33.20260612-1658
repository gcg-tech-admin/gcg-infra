import sys, os, json, glob, argparse, hashlib
from datetime import datetime

BORING = [
    'How is Claude doing this session?',
    'New session started',
    'Models (claude-cli',
    'Here when you need me',
    'I am ready to help',
    'Try "',
    'Meet Fable 5',
    'Included in your plan',
    'bypass permissions on',
    'Run /init to create',
    'What is new',
]

def is_boilerplate(text):
    t = text.strip()
    if len(t) < 20:
        return True
    for p in BORING:
        if p in t:
            return True
    if '1: Bad' in t and '2: Fine' in t:
        return True
    return t.startswith('\nHow is Claude')

def parse_ts(s):
    try:
        return datetime.fromisoformat(str(s).replace('Z', '+00:00')).timestamp()
    except:
        return 0.0

def collect(project_dir, since):
    texts = []
    if not os.path.isdir(project_dir):
        return texts
    for fp in sorted(glob.glob(os.path.join(project_dir, '*.jsonl'))):
        try:
            with open(fp, 'r', errors='replace') as f:
                for line in f:
                    line = line.strip()
                    if not line or '"assistant"' not in line:
                        continue
                    try:
                        o = json.loads(line)
                    except:
                        continue
                    if o.get('type') != 'assistant':
                        continue
                    ts = parse_ts(o.get('timestamp', ''))
                    if ts < since:
                        continue
                    m = o.get('message', {})
                    c = m.get('content')
                    buf = ''
                    if isinstance(c, list):
                        for b in c:
                            if isinstance(b, dict) and b.get('type') == 'text':
                                buf += b.get('text', '')
                    elif isinstance(c, str):
                        buf += c
                    if buf.strip() and not is_boilerplate(buf):
                        texts.append((ts, buf))
        except:
            continue
    texts.sort(key=lambda x: x[0])
    return texts

def main():
    ap = argparse.ArgumentParser()
    ap.add_argument('--project-dir', required=True)
    ap.add_argument('--since', type=float, required=True)
    ap.add_argument('--mode', choices=['check', 'extract'], default='extract')
    a = ap.parse_args()
    texts = collect(a.project_dir, a.since)
    if a.mode == 'check':
        sys.exit(0 if texts else 1)
    out = '\n'.join(t for _, t in texts).strip()
    sys.stdout.write(out)

if __name__ == '__main__':
    main()
