#!/bin/bash
# Claude Interactive TMUX Bridge v36 — JSONL extraction + flock + history (Atlas, 2026-06-11)
#
# Changelog v30 -> v31:
#   (a) Robust response extraction: read the active Claude Code session JSONL under
#       $HOME/.claude/projects/<slug>/ and extract the assistant turn text by a
#       timestamp watermark (records with ts >= send time). Preserves newlines and
#       formatting; no UI chrome. The hardened v30 awk screen-scrape is kept as a
#       fallback when no JSONL text is found.
#   (b) History/context handling: optional --history <text> is prepended to the prompt
#       as a context block. The prompt is no longer flattened (tr '\n' ' ') or hard
#       truncated to 4000 chars — multi-line is preserved via tmux bracketed paste
#       (paste-buffer -p). A sanity cap of 16000 chars remains to avoid runaways.
#   (c) Concurrency: flock per-session lockfile so concurrent calls to the same session
#       queue instead of interleaving.
#   Output JSON is built with python3 json.dumps (correct escaping, newlines as \n),
#       replacing the v30 `tr '\n' ' '` + sed escaping that mangled long responses.
#
# CLI interface is unchanged: --model --prompt --agent (--session-id/--resume ignored),
# positional last-arg, or stdin. New optional: --history <text>.
set -e

HOME_DIR="/opt/gcg/claude-profiles/sub-peter"
WORK_DIR="/opt/gcg/shared"
TIMEOUT=${GCTB_TIMEOUT:-120}
MODEL="sonnet"
PROMPT=""
AGENT_ID=""
HISTORY=""
POSITIONAL=()
HELPER="/opt/gcg/shared/bin/claude-jsonl-extract.py"

while [[ $# -gt 0 ]]; do
    case "$1" in
        --model)    MODEL="$2"; shift 2 ;;
        --prompt)   PROMPT="$2"; shift 2 ;;
        --agent)    AGENT_ID="$2"; shift 2 ;;
        --history)  HISTORY="$2"; shift 2 ;;
        --session-id|--resume) shift 2 ;;
        --*) shift ;;
        *)          POSITIONAL+=("$1"); shift ;;
    esac
done

[[ -z "$PROMPT" && ${#POSITIONAL[@]} -gt 0 ]] && PROMPT="${POSITIONAL[-1]}"
[[ -z "$PROMPT" ]] && PROMPT=$(cat)

if [[ -n "$AGENT_ID" ]]; then
    AGENT_HOME=$(grep "^Environment=" "/etc/systemd/system/openclaw-${AGENT_ID}.service.d/20-claude-cli-home.conf" 2>/dev/null | grep "HOME=" | sed 's/.*HOME=//;s/^"//;s/"$//' || echo "")
    [[ -n "$AGENT_HOME" ]] && HOME_DIR="$AGENT_HOME"
fi

case "$MODEL" in
    sonnet*|claude-sonnet*) CLAUDE_MODEL="claude-sonnet-4-6" ;;
    opus*|claude-opus*)     CLAUDE_MODEL="claude-opus-4-8" ;;
    haiku*|claude-haiku*)   CLAUDE_MODEL="claude-haiku-4-5" ;;
    fable*|claude-fable*)   CLAUDE_MODEL="claude-fable-5" ;;
    *)       echo "ERROR: Unknown model $MODEL" >&2; exit 1 ;;
esac

SEAT_NAME=$(basename "$HOME_DIR")
SESSION_KEY="${AGENT_ID:-$SEAT_NAME}"
TMUX_SESSION="gcg-claude-${CLAUDE_MODEL}-${SESSION_KEY}"

# Per-session working dir so each session's JSONL transcript is isolated. This is
# essential when two agents share one profile (e.g. kenji + vera both on sub-flore):
# a shared cwd would put both transcripts in the same project dir and the timestamp
# extractor could cross-read. A unique cwd gives each session its own project dir.
WORK_DIR="/opt/gcg/shared/bridge-sessions/$SESSION_KEY"
mkdir -p "$WORK_DIR" 2>/dev/null || true

# Project dir holding this session's JSONL transcript (cwd slugified by Claude Code).
WORK_SLUG=$(echo "$WORK_DIR" | sed 's#[/.]#-#g')
PROJECT_DIR="$HOME_DIR/.claude/projects/$WORK_SLUG"

# (c) flock: serialize concurrent calls to the same session.
LOCKFILE="/tmp/gcg-claude-lock-${TMUX_SESSION}"
exec 200>"$LOCKFILE"
if ! flock -w "$TIMEOUT" 200; then
    echo '{"type":"result","result":"","error":"session busy"}'
    exit 1
fi

# (b) Prepend history as context if provided.
if [[ -n "$HISTORY" ]]; then
    PROMPT="Previous context (for continuity):
$HISTORY

Current request:
$PROMPT"
fi

create_fresh_session() {
    tmux kill-session -t "$TMUX_SESSION" 2>/dev/null || true
    tmux new-session -d -s "$TMUX_SESSION" -c "$WORK_DIR" -x 200 -y 50
    tmux set-option -t "$TMUX_SESSION" history-limit 5000 2>/dev/null || true
    tmux send-keys -t "$TMUX_SESSION" "unset ANTHROPIC_API_KEY" C-m
    sleep 0.5
    # Nuke old JSONL to prevent bridge from extracting stale responses
rm -f "$PROJECT_DIR"/*.jsonl 2>/dev/null || true
tmux send-keys -t "$TMUX_SESSION" "HOME=$HOME_DIR IS_SANDBOX=1 DISABLE_AUTOUPDATER=1 claude --model $CLAUDE_MODEL" C-m
    sleep 12
}

# Reuse existing session if it exists (bypass already accepted = no dialog)
if tmux has-session -t "$TMUX_SESSION" 2>/dev/null; then
    # Reuse — check if it is still alive
    true
else
    create_fresh_session
fi

# Only nuke JSONL for fresh sessions — reuse keeps history
# but clear any pre-existing assistant records to avoid stale extraction
sleep 1
SINCE=$(date -u +%s)

# (b) Send prompt preserving newlines via bracketed paste (no flatten, sanity cap 16000).
PROMPT_CAPPED=$(printf '%s' "$PROMPT" | head -c 16000)
printf '%s' "$PROMPT_CAPPED" | tmux load-buffer -
tmux paste-buffer -p -t "$TMUX_SESSION"
sleep 0.3
tmux send-keys -t "$TMUX_SESSION" C-m

# Wait for completion. Signals combined:
#   - "esc to interrupt" working indicator is gone (Claude idle), AND
#   - a new assistant text record exists in JSONL since SINCE, AND
#   - the newest JSONL mtime has been stable for 2 consecutive polls.
elapsed=0
STABLE=0
LAST_MTIME=""
while [[ $elapsed -lt $TIMEOUT ]]; do
    sleep 2; elapsed=$((elapsed + 2))
    PANE=$(tmux capture-pane -t "$TMUX_SESSION" -p -S -8 2>/dev/null || true)
    if echo "$PANE" | grep -qi "to interrupt"; then
        STABLE=0; continue
    fi
    if ! python3 "$HELPER" --project-dir "$PROJECT_DIR" --since "$SINCE" --mode check 2>/dev/null; then
        STABLE=0; continue
    fi
    MT=$(stat -c %Y "$PROJECT_DIR"/*.jsonl 2>/dev/null | sort -n | tail -1)
    if [[ -n "$MT" && "$MT" == "$LAST_MTIME" ]]; then
        STABLE=$((STABLE + 1))
        [[ $STABLE -ge 2 ]] && break
    else
        STABLE=0
    fi
    LAST_MTIME="$MT"
done

# (a) Extract from JSONL (newlines preserved). Fallback to hardened awk screen-scrape.
RESULT=$(python3 "$HELPER" --project-dir "$PROJECT_DIR" --since "$SINCE" --mode extract 2>/dev/null || true)

if [[ -z "${RESULT//[[:space:]]/}" ]]; then
    FULL_PANE=$(tmux capture-pane -t "$TMUX_SESSION" -p -S -200 2>/dev/null || true)
    RESULT=$(echo "$FULL_PANE" | awk '
        /^[[:space:]]*●/ && !/How is Claude doing this session/ {
            block = ""; collecting = 1
        }
        collecting && /❯/ { collecting = 0; next }
        collecting {
            line = $0
            sub(/^[[:space:]]*●[[:space:]]?/, "", line)
            sub(/^[[:space:]]*✻[[:space:]]?/, "", line)
            if (line ~ /^[[:space:]]*[─━—-]{4,}[[:space:]]*$/) next
            if (line ~ /^[[:space:]]*[[:alpha:]…]+ for [0-9]+m?s([[:space:]·].*)?$/) next
            if (line !~ /^[[:space:]]*$/) block = block line "\n"
        }
        END { printf "%s", block }
    ')
fi

# Emit result JSON with correct escaping (newlines preserved as \n).
printf '%s' "$RESULT" | python3 -c 'import sys,json; print(json.dumps({"type":"result","result":sys.stdin.read()}))'
