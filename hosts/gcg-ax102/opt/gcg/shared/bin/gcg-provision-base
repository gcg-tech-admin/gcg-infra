#!/usr/bin/env python3
"""
gcg-provision-base — Tier 1 (identity), Tier 2 (security), Tier 3 (model routing),
                      Tier 7 (systemd) provisioner for OpenClaw fleet agents.

Usage:
  gcg-provision-base <name> --tier {A|B|C|D} [--role "<role>"] [--dry-run]
                     [--no-systemd] [--backup-only] [--force] [--start]

Spec:    /opt/gcg/shared/AGENT_SPEC.md
Playbook: /opt/gcg/shared/AGENT_DEPLOYMENT_PLAYBOOK.md
QA tool: /opt/gcg/shared/bin/gcg-agent-qa
"""
from __future__ import annotations

import argparse
import json
import os
import re
import secrets
import subprocess
import sys
import time
from dataclasses import dataclass, field
from pathlib import Path
from typing import Any

# ─── constants ────────────────────────────────────────────────────────────────

AGENT_BASE     = "/opt/gcg/openclaw-{name}"
SHARED_BIN     = "/opt/gcg/shared/bin"
FLEET_YAML     = "/opt/gcg/shared/FLEET.yaml"
CREDSTORE_DIR  = "/etc/credstore.encrypted"
SYSTEMD_DIR    = "/etc/systemd/system"
AUDIT_LOG      = "/var/log/gcg-provision/base.log"
BOOTSTRAP_SCRIPT = f"{SHARED_BIN}/gcg-secret-bootstrap.sh"
VALIDATE_SCRIPT  = "/opt/gcg/shared/scripts/validate-agent-config.py"

CRITICAL_6 = {"daen", "talos", "marcus", "mnemosyne", "vulcan", "nik"}
VALID_TIERS = {"A", "B", "C", "D"}

# Ports are assigned sequentially; base is 18800, each agent gets a unique port.
# Provisioner auto-assigns the next free port (reads existing FLEET.yaml entries).
PORT_BASE = 18800

# Name validation: kebab-case, lowercase alphanumeric + hyphen, 2–32 chars
NAME_RE = re.compile(r'^[a-z][a-z0-9\-]{1,31}$')

# ─── model routing tables ────────────────────────────────────────────────────

