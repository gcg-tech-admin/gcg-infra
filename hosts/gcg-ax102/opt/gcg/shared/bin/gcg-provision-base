# Auth-profile templates (mode declarations; actual keys are injected at runtime by bootstrap)
AUTH_PROFILES: dict[str, dict] = {
    "anthropic:default":    {"provider": "anthropic",    "mode": "api_key"},
    "deepseek:default":     {"provider": "deepseek",     "mode": "api_key"},
    "moonshot:default":     {"provider": "moonshot",     "mode": "api_key"},
    "google:default":       {"provider": "google",       "mode": "api_key"},
    "openai:default":       {"provider": "openai",       "mode": "api_key"},
